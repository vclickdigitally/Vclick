# 1. DATABASE CONNECTIVITY
# Database connection string for PostgreSQL. Mapped in prisma/schema.prisma
DATABASE_URL="postgresql://username:password@localhost:5432/vclick_cms?schema=public"

# 2. AUTHENTICATION & SECURITY (Auth.js v5)
# A cryptographically secure 32-character secret key. Generate locally via: npx auth secret
AUTH_SECRET="your-32-character-random-secret-key-placeholder"

# NextAuth base URL (required in dev environments)
NEXTAUTH_URL="http://localhost:3000"

# 3. MAIL & NOTIFICATIONS (SMTP Configurations)
# Hostinger SMTP, Mailtrap, or standard credentials
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="smtp-username"
SMTP_PASSWORD="smtp-password"
SMTP_FROM="noreply@vclickdigitally.com"

# 4. ARTIFICIAL INTELLIGENCE (Gemini Developer Key)
# Configured for dynamic CMS SEO suggestions and post revisions (Phase 6)
GEMINI_API_KEY="your-gemini-api-studio-key"

# 5. PUBLIC ACCESS URL
# Host URL configuration
APP_URL="http://localhost:3000"
