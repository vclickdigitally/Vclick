datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  SUPERADMIN
  ADMIN
  EDITOR
  AUTHOR
  CONTRIBUTOR
}

enum RedirectCode {
  R301
  R302
  R307
  R308
  R410
  R451
}

// 1. ADMINISTRATIVE USERS & SESSIONS (Auth.js v5 + EEAT Profiles)
model User {
  id             String          @id @default(uuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  password       String          // Hashed password
  image          String?
  role           RoleType        @default(AUTHOR)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // EEAT Author Credentials
  bio            String?         @db.Text
  credentials    String?         // E.g. "Google Certified SEO Expert"
  twitterUrl     String?
  linkedinUrl    String?
  websiteUrl     String?

  accounts       Account[]
  sessions       Session[]
  seoHistory     SEOHistory[]
  pageHistory    PageHistory[]
  blogHistory    BlogHistory[]
  auditLogs      AuditLog[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 2. GLOBAL REGISTRIES & SETTINGS
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique // E.g. "google_analytics_id", "sitemap_auto_ping"
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebsiteSettings {
  id                    String   @id @default(uuid())
  name                  String   @default("VClick Digitally")
  domain                String   @default("vclickdigitally.com")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations to modular global SEO configuration (canonical url, default social cards)
  globalSEOId           String?  @unique
  globalSEO             SEOConfiguration? @relation("GlobalSEO", fields: [globalSEOId], references: [id])
}

// 3. SEO CENTER: REDIRECTS, SCHEMAS & LINK RELATION MANAGEMENT
model Redirect {
  id          String       @id @default(uuid())
  source      String       @unique
  destination String
  code        RedirectCode @default(R301)
  active      Boolean      @default(true)
  hitCount    Int          @default(0)
  lastHitAt   DateTime?
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SchemaTemplate {
  id              String   @id @default(uuid())
  name            String   // E.g. "FAQ Schema", "Organization Schema"
  description     String?
  type            String   // E.g. "FAQPage", "LocalBusiness"
  templateJson    String   @db.Text // JSON blueprint structure with placeholder tokens
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LinkRelation {
  id            String   @id @default(uuid())
  sourcePageId  String?
  sourcePage    Page?    @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)
  sourceBlogId  String?
  sourceBlog    BlogPost? @relation(fields: [sourceBlogId], references: [id], onDelete: Cascade)
  
  targetUrl     String
  anchorText    String
  isExternal    Boolean  @default(false)
  isBroken      Boolean  @default(false)
  statusCode    Int?     // E.g. 200, 404, 500
  checkedAt     DateTime @default(now())

  @@index([sourcePageId])
  @@index([sourceBlogId])
}

// 4. NORMALIZED CONTENT & SEO ENGINES
model Page {
  id              String            @id @default(uuid())
  slug            String            @unique
  title           String
  content         String            @db.Text // Rich-text content
  published       Boolean           @default(false)
  publishedAt     DateTime?         @default(now())
  scheduledAt     DateTime?         // Future publish schedule date
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  seoConfig       SEOConfiguration?
  featuredImage   String?
  featuredImageAlt String?
  
  links           LinkRelation[]
  history         PageHistory[]
}

model PageHistory {
  id              String   @id @default(uuid())
  pageId          String
  page            Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title           String
  content         String   @db.Text
  featuredImage   String?
  featuredImageAlt String?
  
  changedById     String
  changedBy       User     @relation(fields: [changedById], references: [id])
  createdAt       DateTime @default(now())
}

model BlogPost {
  id              String            @id @default(uuid())
  slug            String            @unique
  title           String
  content         String            @db.Text
  published       Boolean           @default(false)
  publishedAt     DateTime?         @default(now())
  scheduledAt     DateTime?         // Future publish schedule date
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  seoConfig       SEOConfiguration?
  featuredImage   String?
  featuredImageAlt String?
  
  links           LinkRelation[]
  history         BlogHistory[]
}

model BlogHistory {
  id              String   @id @default(uuid())
  blogId          String
  blog            BlogPost @relation(fields: [blogId], references: [id], onDelete: Cascade)
  title           String
  content         String   @db.Text
  featuredImage   String?
  featuredImageAlt String?
  
  changedById     String
  changedBy       User     @relation(fields: [changedById], references: [id])
  createdAt       DateTime @default(now())
}

// 5. SEO METADATA & CALCULATED DIAGNOSTICS
model SEOConfiguration {
  id              String         @id @default(uuid())
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  secondaryKeywords String?       // Comma-separated or JSON list
  noIndex         Boolean        @default(false)
  noFollow        Boolean        @default(false)
  canonicalUrl    String?
  metaRobotsAdvanced String?      // E.g. "max-snippet:-1, max-image-preview:large"
  breadcrumbTitle String?         // Custom SEO breadcrumb link override
  
  // Social Previews OpenGraph / Twitter Cards
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  
  twitterTitle    String?
  twitterDescription String?
  twitterImage    String?
  twitterCard     String?        @default("summary_large_image")
  
  // Custom JSON-LD Injector
  structuredData  String?        @db.Text
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Mapped relations
  pageId          String?        @unique
  page            Page?          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  blogId          String?        @unique
  blog            BlogPost?      @relation(fields: [blogId], references: [id], onDelete: Cascade)

  globalSettings  WebsiteSettings? @relation("GlobalSEO")

  analysis        SEOAnalysis?
  history         SEOHistory[]
}

model SEOAnalysis {
  id               String           @id @default(uuid())
  seoConfigId      String           @unique
  seoConfig        SEOConfiguration @relation(fields: [seoConfigId], references: [id], onDelete: Cascade)
  
  // Diagnostic Score Metric Cards (0 - 100)
  overallScore     Int              @default(0)
  seoScore         Int              @default(0)
  readabilityScore Int              @default(0)
  technicalScore   Int              @default(0)
  schemaScore      Int              @default(0)
  imagesScore      Int              @default(0)
  eeatScore        Int              @default(0)
  
  // Reading & Density metrics
  wordCount        Int              @default(0)
  readingTime      Int              @default(0) // In minutes
  keywordDensity   Float            @default(0.0)
  readabilityGrade String?          // E.g. "Flesch: Grade 8"
  
  // JSON array of errors, warning items, and positive checkpoints
  issuesJson       String?          @db.Text
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model SEOHistory {
  id              String           @id @default(uuid())
  seoConfigId     String
  seoConfig       SEOConfiguration @relation(fields: [seoConfigId], references: [id], onDelete: Cascade)
  
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  noIndex         Boolean
  noFollow        Boolean
  canonicalUrl    String?
  structuredData  String?          @db.Text
  
  changedById     String
  changedBy       User             @relation(fields: [changedById], references: [id])
  createdAt       DateTime         @default(now())
}

// 6. MEDIA DAM LIBRARY
model MediaAsset {
  id              String   @id @default(uuid())
  filename        String
  url             String
  altText         String?
  title           String?
  caption         String?
  description     String?  @db.Text
  size            Int
  mimeType        String
  folder          String   @default("root")
  width           Int?
  height          Int?
  hash            String?  // SHA-256 for duplicate detection
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 7. SECURITY AUDIT LOGS
model AuditLog {
  id                 String          @id @default(uuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  action             String          // E.g. "PUBLISH_PAGE", "REDIRECT_CREATE"
  details            String?         @db.Text
  ipAddress          String?
  createdAt          DateTime        @default(now())
}
